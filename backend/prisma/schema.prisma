datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  organizer
  sponsor
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  events Event[] @relation("OrganizerEvents")
  sponsor Sponsor?
}

model Event {
  id         String   @id @default(uuid())
  name       String
  date       DateTime
  location   String
  revenue    Float
  attendees  Int
  engagement Float
  createdAt  DateTime @default(now())

  organizerId String?
  organizer   User?   @relation("OrganizerEvents", fields: [organizerId], references: [id])

  sponsors Sponsorship[]
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  sponsorships Sponsorship[]
}

model Sponsorship {
  id String @id @default(uuid())

  eventId   String
  sponsorId String

  investment  Float
  boothVisits Int
  leads       Int

  event   Event   @relation(fields: [eventId], references: [id])
  sponsor Sponsor @relation(fields: [sponsorId], references: [id])
}

model ImportLog {
  id        String   @id @default(uuid())
  filename  String
  rows      Int
  status    String
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(uuid())
  name      String
  type      String
  format    String
  fileUrl   String
  createdAt DateTime @default(now())
}